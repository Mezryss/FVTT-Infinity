<div class="w-full text-center text-xl {{#if isGM}}text-red-800{{else}}text-blue-800{{/if}}">
	{{#if wasSpend}}
		<span>{{ localize 'Infinity.ChatMessages.SpendMomentum' amount=amount }}</span>
	{{else}}
		<span>{{ localize 'Infinity.ChatMessages.StoreMomentum' amount=amount }}</span>
	{{/if}}
</div>
