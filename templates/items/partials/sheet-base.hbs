{{!-- Base layout and styling shared by many Item sheets. --}}
{{#> core/sheet-base }}
	{{#> core/title-box }}
		<img src="{{ item.img }}" data-edit="img" class="aspect-square h-14 border-none bg-sky-300 bg-opacity-75 hover:cursor-pointer rounded-md" />
		<div class="flex flex-col flex-nowrap gap-0.5 w-full">
			<input type="text" name="name" value="{{ item.name }}" placeholder="Item Name" class="!text-sky-50 !text-lg !border-none !appearance-none !focus:outline-none !focus:shadow-none !focus:bg-white !focus:bg-opacity-5 !font-bold" />
			<div class="flex gap-1 text-sm items-center">
				<strong>{{ localize "Labels.Source" }}:</strong>
				{{> core/linkable-text-field name="system.source" value=system.source class="!text-white" }}
			</div>
		</div>
	{{/core/title-box}}

	<div class="flex flex-nowrap h-full w-full gap-2">
		{{#if sidebarPartial}}
			<div class="h-full w-48 flex-shrink-0 bg-sky-400 bg-opacity-20 rounded-md p-1">
				<div class="flex flex-col flex-nowrap w-full h-full gap-0.5 px-1">
					{{> (lookup . 'sidebarPartial') }}
				</div>
			</div>
		{{/if}}

		<div class="w-full h-full flex flex-col flex-nowrap @container">
			{{#> core/tab-bar }}
				{{#> core/tab-link tab="description"}}{{ localize "Tabs.Description" }}{{/core/tab-link}}
				{{#> core/tab-link tab="detail"}}{{ localize "Tabs.Detail" }}{{/core/tab-link}}
				{{#if showEffects}}
					{{#> core/tab-link tab="effects"}}{{ localize "Tabs.Effects" }}{{/core/tab-link}}
				{{/if}}
			{{/core/tab-bar}}

			<section class="sheet-body w-full h-full @container/body">
				{{#> core/tab-content tab="detail" }}
					{{> @partial-block }}
				{{/core/tab-content}}

				{{#> core/tab-content tab="description" }}
					<div class="flex flex-col items-start gap-2 h-full w-full">
						{{ editor enrichedDescription target="system.description" button=true editable=editable engine="prosemirror" }}
					</div>
				{{/core/tab-content}}
			</section>
		</div>
	</div>
{{/core/sheet-base}}
