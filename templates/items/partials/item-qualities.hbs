<div class="flex flex-col flex-nowrap {{ class }}">
	<span class="text-lg font-orbitron font-semibold">{{ localize "Items.Qualities.Label" }}</span>
	{{#if itemQualities }}
		<div class="flex flex-wrap gap-1 ml-4">
			{{#each itemQualities}}
				<input type="hidden" name="{{concat "system.qualities." @index ".uuid" }}" value="{{ uuid }}" />

				<div class="flex gap-1 items-center rounded-md border-1 border-solid border-slate-900 px-1 py-0.5 bg-slate-900 bg-opacity-10 hover:bg-opacity-20">
					{{!-- Quality Name & non-editable display --}}
					<a class="flex gap-1" data-action="open-sheet" data-uuid="{{ uuid }}" data-tooltip="{{ system.description }}">
						<span>{{ name }}</span>
						{{#unless @root.editable}}
							{{#if system.isSpecialized}}
								<span>({{#if specialization}}{{ specialization }}{{else}}{{ system.specializationPlaceholder }}{{/if}})</span>
							{{/if}}
							{{#if system.isRanked}}
								<span>{{ rating }}</span>
							{{/if}}
						{{/unless}}
					</a>

					{{#if @root.editable}}
						{{!-- Specialization --}}
						{{#if system.isSpecialized}}
							{{> core/field type="text" name=(concat "system.qualities." @index ".specialization") value=specialization placeholder=system.specializationPlaceholder class="!text-sm !w-20 !text-center !rounded-sm !h-6" }}
						{{else}}
							<input type="hidden" name="{{concat "system.qualities." @index ".specialization" }}" value="{{ specialization }}" />
						{{/if}}

						{{!-- Rating --}}
						{{#if system.isRanked}}
							{{> core/field type="number" name=(concat "system.qualities." @index ".rating") value=rating class="!text-sm !w-8 !text-center !rounded-sm !h-6" min="1" }}
						{{else}}
							<input type="hidden" name="{{concat "system.qualities." @index ".rating" }}" value="1" />
						{{/if}}

						{{!-- Delete Button --}}
						<a class="px-1 relative text-sm -my-2" data-action="delete-quality" data-uuid="{{ uuid }}">
							<i class="fas fa-trash"></i>
						</a>
					{{/if}}
				</div>
			{{/each}}
		</div>
	{{else}}
		<em class="ml-4 oblique">{{ localize "Items.Qualities.None" }}</em>
	{{/if}}
</div>
